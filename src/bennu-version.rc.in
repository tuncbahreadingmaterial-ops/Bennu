#include <windows.h>

CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "@BENNU_MANIFEST_RESOURCE_PATH@"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @BENNU_VERSION_MAJOR@,@BENNU_VERSION_MINOR@,@BENNU_VERSION_PATCH@,0
 PRODUCTVERSION @BENNU_VERSION_MAJOR@,@BENNU_VERSION_MINOR@,@BENNU_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "Bennu contributors\0"
      VALUE "FileDescription", "Bennu data-oriented programming language\0"
      VALUE "FileVersion", "@BENNU_VERSION@\0"
      VALUE "InternalName", "bennu\0"
      VALUE "LegalCopyright", "Bennu contributors\0"
      VALUE "OriginalFilename", "bennu.exe\0"
      VALUE "ProductName", "Bennu\0"
      VALUE "ProductVersion", "@BENNU_VERSION@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
